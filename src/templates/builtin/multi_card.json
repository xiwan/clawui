{
  "id": "multi_card",
  "version": "v0.8",
  "description": "Grid of cards with optional actions",
  "dataSchema": {
    "title": "string",
    "columns": "number",
    "cards": "array"
  },
  "components": [
    { "id": "root", "component": "Column", "children": ["header", "grid"] },
    { "id": "header", "component": "Text", "text": "{{title}}", "variant": "h1" },
    { "id": "grid", "component": "Column", "children": [] }
  ]
}
